let numeros = [];
let maior;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Considera o primeiro número como o maior
maior = numeros[0];

// Procurar o maior número
for (let i = 1; i < 5; i++) {
    if (numeros[i] > maior) {
        maior = numeros[i];
    }
}

// Mostrar o maior número
document.write("O maior número digitado foi: " + maior);
