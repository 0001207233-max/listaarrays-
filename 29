let numeros = [];
let soma = 0;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Somar apenas os números pares
for (let i = 0; i < 5; i++) {
    if (numeros[i] % 2 == 0) {
        soma += numeros[i];
    }
}

// Mostrar o resultado
document.write("A soma dos números pares é: " + soma);
