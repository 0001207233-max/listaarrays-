let numeros = [];

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Mostrar apenas os números positivos
document.write("Números positivos:<br>");

for (let i = 0; i < 5; i++) {
    if (numeros[i] > 0) {
        document.write(numeros[i] + "<br>");
    }
}
