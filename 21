let numeros = [];
let menor;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Considera o primeiro número como o menor
menor = numeros[0];

// Procurar o menor número
for (let i = 1; i < 5; i++) {
    if (numeros[i] < menor) {
        menor = numeros[i];
    }
}

// Mostrar o menor número
document.write("O menor número digitado foi: " + menor);
