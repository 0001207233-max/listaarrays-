let numeros = [];
let soma = 0;
let media;

// Ler 5 números reais
for (let i = 0; i < 5; i++) {
    numeros[i] = parseFloat(prompt("Digite um número:"));
}

// Somar os números
for (let i = 0; i < 5; i++) {
    soma += numeros[i];
}

// Calcular a média
media = soma / 5;

// Mostrar o resultado
document.write("A média dos números é: " + media);
