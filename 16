let numeros = [];

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Substituir os negativos por zero
for (let i = 0; i < 5; i++) {
    if (numeros[i] < 0) {
        numeros[i] = 0;
    }
}

// Mostrar o vetor resultante
document.write("Vetor resultante:<br>");

for (let i = 0; i < 5; i++) {
    document.write(numeros[i] + "<br>");
}
