let numeros = [];
let soma = 0;

// Ler 5 números
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Somar os elementos do vetor
for (let i = 0; i < 5; i++) {
    soma += numeros[i];
}

// Mostrar o resultado
document.write("A soma dos números é: " + soma);
