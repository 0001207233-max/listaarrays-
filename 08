let numeros = [];

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Mostrar as posições dos números negativos
document.write("Posições dos números negativos:<br>");

for (let i = 0; i < 5; i++) {
    if (numeros[i] < 0) {
        document.write("Posição " + i + "<br>");
    }
}
