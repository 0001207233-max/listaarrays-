let numeros = [];
let soma = 0;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Somar os elementos das posições pares
for (let i = 0; i < 5; i++) {
    if (i % 2 == 0) {
        soma += numeros[i];
    }
}

// Mostrar o resultado
document.write("A soma dos elementos das posições pares é: " + soma);
