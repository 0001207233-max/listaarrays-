let numeros = [];
let produto = 1;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Calcular o produto dos elementos
for (let i = 0; i < 5; i++) {
    produto = produto * numeros[i];
}

// Mostrar o resultado
document.write("O produto dos números é: " + produto);
