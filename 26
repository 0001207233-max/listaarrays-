let numeros = [];
let maior;
let posicao;

// Ler 5 números inteiros
for (let i = 0; i < 5; i++) {
    numeros[i] = parseInt(prompt("Digite um número inteiro:"));
}

// Considerar o primeiro número como o maior
maior = numeros[0];
posicao = 0;

// Encontrar o maior valor e sua posição
for (let i = 1; i < 5; i++) {
    if (numeros[i] > maior) {
        maior = numeros[i];
        posicao = i;
    }
}

// Mostrar o resultado
document.write("O maior valor é " + maior + "<br>");
document.write("Ele está na posição " + posicao);
